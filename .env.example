# ─── GitHub OAuth App Configuration ─────────────────────
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:5173/callback
#
# IMPORTANT: Enable PKCE for your OAuth App in GitHub settings
# (Apps → OAuth Apps → your app → "Allow device flow" or "PKCE")

VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# ─── Redirect URI ─────────────────────────────────────────
# Must match exactly what is set in your GitHub OAuth App settings
VITE_REDIRECT_URI=http://localhost:5173/callback

# ─── Token Exchange Proxy ─────────────────────────────────
# GitHub's token endpoint lacks CORS headers for browser requests.
# This proxy handles the one-time token exchange.
# Default (corsproxy.io) works out of the box for testing.
# For production, deploy your own proxy or Netlify edge function.
#
# Option A – corsproxy.io (default, good for testing):
# VITE_TOKEN_PROXY_URL=https://corsproxy.io/?url=https://github.com/login/oauth/access_token
#
# Option B – your own proxy (recommended for production):
# VITE_TOKEN_PROXY_URL=https://your-proxy.netlify.app/api/token
